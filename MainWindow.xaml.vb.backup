    Private Sub CreateWinPE_Click(sender As Object, e As RoutedEventArgs)
        ' Start WinPE creation wizard - Architecture selection
        If _winPeState <> WinPeWizardState.Idle Then
            Return
        End If

        _winPeState = WinPeWizardState.SelectingArchitecture
        _selectedWinPeArchitecture = Nothing
        _selectedOptionalComponents.Clear()

        ' Show architecture selection UI
        MessageBox.Show("WinPE creation wizard would start here." & Environment.NewLine &
                       "Architecture selection → Optional components → Build",
                       "WinPE Wizard",
                       MessageBoxButton.OK,
                       MessageBoxImage.Information)

        ' Reset state
        _winPeState = WinPeWizardState.Idle
    End Sub

