    Private Function GetLogFilePath(baseDirectory As String) As String
        Try
            Dim logsFolder = Path.Combine(baseDirectory, ImageLogRelativeFolder)
            Directory.CreateDirectory(logsFolder)
            Return Path.Combine(logsFolder, ImageLogFileName)
        Catch ex As Exception
            Debug.WriteLine($"Failed to get log file path: {ex.Message}")
            Return Nothing
        End Try
    End Function

    Private Sub WriteToLog(logFilePath As String, message As String)
        If String.IsNullOrWhiteSpace(logFilePath) Then Return
        Try
            SyncLock _logSyncRoot
                File.AppendAllText(logFilePath, message & Environment.NewLine)
            End SyncLock
        Catch ex As Exception
            Debug.WriteLine($"Failed to write to log: {ex.Message}")
        End Try
    End Sub

